<Window x:Class="TransparentTwitchChatWPF.Input_BlazeSecret"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:ThemeManager.RequestedTheme="Dark"
        WindowStyle="ToolWindow"
        Topmost="True"
        Width="400" Height="200"
        Background="#1A1A1A"
        Title="Configure Blaze Client Secret"
        WindowStartupLocation="CenterOwner"
        ContentRendered="Window_ContentRendered">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="Gray" FontSize="12"
                   Text="Enter your Blaze Client Secret. It will be encrypted with Windows DPAPI and stored locally — it will never be committed to source control." />

        <PasswordBox Name="pbSecret" Grid.Row="1" Margin="0,12,0,0" Height="26" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="75" Margin="0,0,8,0" Click="OKButton_Click" IsDefault="True" />
            <Button Content="Cancel" Width="75" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
